NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
AUTH_SECRET=replace_with_very_long_random_secret
# For host-machine workflows (npm run dev on your laptop):
DATABASE_URL=postgresql://rightbricks:replace_me@localhost:5432/rightbricks
# Docker Compose overrides DATABASE_URL for the web container to use host `db`.
POSTGRES_DB=rightbricks
POSTGRES_USER=rightbricks
POSTGRES_PASSWORD=replace_me

SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_USER=contact@rightbricks.online
SMTP_PASS=replace_with_real_password
SMTP_SECURE=true
SMTP_FROM=RightBricks <contact@rightbricks.online>
