generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  RENTER
  SELLER
  LANDLORD
  DEVELOPER
  AGENT_PARTNER
  OPS
  ADMIN
}

enum ListingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  PUBLISHED
  PAUSED
  REJECTED
  ARCHIVED
}

enum RequestStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  username          String               @unique
  passwordHash      String
  role              UserRole             @default(BUYER)
  isVerified        Boolean              @default(false)
  isActive          Boolean              @default(true)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  profile           Profile?
  savedListings     SavedListing[]
  viewingRequests   ViewingRequest[]
  listingReports    ListingReport[]
  shares            ListingShare[]
  passwordResets    PasswordReset[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  fullName    String
  phone       String?
  locale      String   @default("en-KH")
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ListingActionBase {
  id          String   @id @default(cuid())
  listingSlug String
  createdAt   DateTime @default(now())
}

model SavedListing {
  id          String   @id @default(cuid())
  userId      String
  listingSlug String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingSlug])
  @@index([listingSlug])
}

model ViewingRequest {
  id             String        @id @default(cuid())
  userId         String?
  listingSlug    String
  fullName       String
  email          String
  phone          String
  preferredDate  DateTime
  notes          String?
  status         RequestStatus @default(NEW)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([listingSlug, createdAt])
}

model ListingReport {
  id          String        @id @default(cuid())
  userId      String?
  listingSlug String
  reason      String
  notes       String?
  status      RequestStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([listingSlug, createdAt])
}

model ListingShare {
  id          String   @id @default(cuid())
  userId      String?
  listingSlug String
  channel     String
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([listingSlug, createdAt])
}

model PasswordReset {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ManagedListing {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String
  priceUsd    Int
  city        String
  district    String
  propertyType String
  intent      String
  status      ListingStatus @default(DRAFT)
  featured    Boolean       @default(false)
  imageUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, createdAt])
}
