generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  RENTER
  SELLER
  LANDLORD
  DEVELOPER
  AGENT_PARTNER
  OPS
  ADMIN
}

enum ListingStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  PUBLISHED
  PAUSED
  REJECTED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VIEWING_BOOKED
  OFFER_MADE
  CLOSED_WON
  CLOSED_LOST
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  role          UserRole
  isVerified    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  profile       Profile?
  listings      Listing[]
  leadsOwned    Lead[]      @relation("LeadOwner")
  offers        Offer[]
  notifications Notification[]
  auditLogs     AuditLog[]  @relation("AuditActor")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  fullName    String
  phone       String?
  locale      String   @default("en-KH")
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Area {
  id          String     @id @default(cuid())
  city        String
  district    String
  slug        String     @unique
  seoTitle    String?
  seoDesc     String?
  listings    Listing[]
  createdAt   DateTime   @default(now())
}

model Listing {
  id               String        @id @default(cuid())
  ownerId          String
  areaId           String
  title            String
  slug             String        @unique
  description      String
  propertyType     String
  intent           String
  price            Decimal       @db.Decimal(14, 2)
  currency         String        @default("USD")
  bedrooms         Int?
  bathrooms        Int?
  floorAreaSqm     Decimal?      @db.Decimal(8, 2)
  landAreaSqm      Decimal?      @db.Decimal(8, 2)
  status           ListingStatus @default(DRAFT)
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  owner            User          @relation(fields: [ownerId], references: [id])
  area             Area          @relation(fields: [areaId], references: [id])
  media            ListingMedia[]
  leads            Lead[]
  offers           Offer[]

  @@index([status, updatedAt])
  @@index([intent, propertyType, price])
  @@index([areaId, status])
}

model ListingMedia {
  id          String   @id @default(cuid())
  listingId   String
  url         String
  mimeType    String
  sizeBytes   Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
}

model Lead {
  id            String     @id @default(cuid())
  listingId      String
  ownerId        String
  name           String
  email          String
  phone          String?
  message        String?
  status         LeadStatus @default(NEW)
  source         String      @default("property_detail")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  listing        Listing     @relation(fields: [listingId], references: [id])
  owner          User        @relation("LeadOwner", fields: [ownerId], references: [id])

  @@index([ownerId, status, createdAt])
}

model Offer {
  id            String   @id @default(cuid())
  listingId      String
  userId         String
  amount         Decimal  @db.Decimal(14, 2)
  currency       String   @default("USD")
  status         String   @default("PENDING")
  note           String?
  createdAt      DateTime @default(now())
  listing        Listing  @relation(fields: [listingId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@index([listingId, status])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([targetType, targetId])
  @@index([createdAt])
}
