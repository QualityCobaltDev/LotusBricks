generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ListingType {
  SALE
  RENT
  COMMERCIAL
  LAND
  LUXURY
  INVESTMENT
}

enum PropertyCategory {
  VILLA
  CONDO
  APARTMENT
  TOWNHOUSE
  PENTHOUSE
  OFFICE
  SHOPHOUSE
  LAND
  WAREHOUSE
}

enum PropertyAvailability {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  UNDER_OFFER
}

enum FurnishingType {
  FULLY_FURNISHED
  SEMI_FURNISHED
  UNFURNISHED
  NOT_APPLICABLE
}

enum PlanTier {
  TIER_1
  TIER_2
  TIER_3
  CUSTOM
}

enum InquiryType {
  LISTING
  CUSTOM_PLAN
  GENERAL
  CONTACT
  VALUATION
  LISTING_SUBMISSION
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VIEWING_SCHEDULED
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum EmailStatus {
  SENT
  FAILED
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String
  role          UserRole      @default(CUSTOMER)
  fullName      String
  phone         String?
  planTier      PlanTier      @default(TIER_1)
  signupFeePaid Boolean       @default(false)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  favorites     Favorite[]
  inquiries     Inquiry[]
  listings      Listing[]
  passwordResets PasswordResetToken[]

  @@index([role])
  @@index([planTier])
}

model Listing {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  listingType  ListingType    @default(RENT)
  category     PropertyCategory @default(CONDO)
  availability PropertyAvailability @default(AVAILABLE)
  summary      String
  heroDescription String?
  description  String
  fullDescription String?
  city         String
  district     String
  country      String         @default("Cambodia")
  commune      String?
  streetAddress String?
  mapLabel     String?
  latitude     Float?
  longitude    Float?
  neighborhoodSummary String?
  currency     String         @default("USD")
  priceUsd     Int
  priceSuffix  String?
  originalPriceUsd Int?
  negotiable   Boolean        @default(false)
  serviceFees  String?
  annualManagementFee String?
  depositTerms String?
  paymentTerms String?
  bedrooms     Int
  bathrooms    Int
  areaSqm      Int
  landAreaSqm  Int?
  floors       Int?
  parkingSpaces Int?
  furnishing   FurnishingType @default(FULLY_FURNISHED)
  titleType    String?
  yearBuilt    Int?
  renovatedYear Int?
  orientation  String?
  propertyCondition String?
  keySellingPoints Json?
  idealFor     Json?
  neighborhoodBenefits Json?
  investmentHighlights Json?
  features     Json?
  indoorFeatures Json?
  outdoorFeatures Json?
  securityFeatures Json?
  lifestyleFeatures Json?
  floorPlanImage String?
  brochurePdf  String?
  availabilityDate DateTime?
  viewingAvailability String?
  agentName    String?
  agentRole    String?
  contactPhone String?
  contactEmail String?
  whatsappAvailable Boolean @default(true)
  telegramAvailable Boolean @default(true)
  enquirySubjectTemplate String?
  seoTitle     String?
  seoDescription String?
  openGraphImage String?
  structuredData Json?
  badges       Json?
  breadcrumbs  Json?
  similarListings Json?
  sortOrder    Int            @default(100)
  status       ListingStatus  @default(DRAFT)
  featured     Boolean        @default(false)
  ownerId      String?
  publishedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  media        ListingMedia[]
  favorites    Favorite[]
  inquiries    Inquiry[]
  owner        User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([status, featured])
  @@index([city])
  @@index([ownerId])
}

model ListingMedia {
  id          String   @id @default(cuid())
  listingId   String
  url         String
  kind        String
  alt         String?
  caption     String?
  thumbnail   String?
  title       String?
  description String?
  isPrimary   Boolean  @default(false)
  sortOrder   Int      @default(0)
  sourceType  String   @default("upload")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  listingId  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Inquiry {
  id                String      @id @default(cuid())
  listingId         String?
  userId            String?
  fullName          String
  email             String
  phone             String?
  companyName       String?
  requestedListings Int?
  inquiryType       InquiryType @default(LISTING)
  selectedPlan      String?
  message           String
  sourcePage        String?
  status            LeadStatus  @default(NEW)
  isUrgent          Boolean     @default(false)
  assignedTo        String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  listing           Listing?    @relation(fields: [listingId], references: [id], onDelete: SetNull)
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([inquiryType, createdAt])
  @@index([assignedTo])
}

model PricingPlan {
  id          String   @id @default(cuid())
  name        String
  priceLabel  String
  cadence     String
  ctaLabel    String
  features    Json
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  body      String
  meta      Json?
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id         String      @id @default(cuid())
  type       String
  recipient  String
  subject    String
  status     EmailStatus @default(SENT)
  error      String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([type, createdAt])
  @@index([status, createdAt])
}


model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
