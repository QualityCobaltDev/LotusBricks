{
  "name": "rightbricks",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate --config ./prisma.config.ts",
    "prisma:seed": "tsx prisma/seed.ts",
    "qa:verify": "node scripts/verify-release.mjs",
    "seed": "tsx prisma/seed.ts",
    "prisma:push": "prisma db push --config ./prisma.config.ts",
    "prisma:reset": "npm run prisma:push -- --force-reset && npm run seed",
    "seed:backfill-media": "tsx prisma/backfill-demo-media.ts",
    "test:media": "tsx --test src/lib/__tests__/listing-media.test.ts",
    "prisma:validate": "prisma validate --config ./prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config ./prisma.config.ts",
    "test:routing": "tsx --test src/lib/__tests__/routing.test.ts",
    "qa:routes": "node scripts/route-integrity-check.mjs",
    "seed:backfill-listing-integrity": "tsx prisma/backfill-listing-integrity.ts",
    "test:listing-validation": "tsx --test src/lib/__tests__/listing-validation.test.ts",
    "test:metadata": "tsx --test src/lib/__tests__/metadata.test.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "next": "15.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.1",
    "eslint-config-next": "15.2.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "prisma": "6.19.2"
  }
}
